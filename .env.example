# ─────────────────────────────────────────
# Nelliy's Rewards — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── Database ──────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/nelliy_rewards"

# ── NextAuth ──────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Admin Panel Auth ──────────────────────
# All three are REQUIRED — no defaults in production
ADMIN_USERNAME="your-admin-username"
ADMIN_PASSWORD="your-strong-admin-password"
# Generate with: openssl rand -hex 32
ADMIN_SECRET="your-admin-secret-token"

# ── Receipt QR Security ───────────────────
# Generate with: openssl rand -hex 32
# REQUIRED — no default in production
RECEIPT_QR_SECRET="your-receipt-qr-secret"

# ── EmailJS (transactional emails) ────────
# Get from https://www.emailjs.com/
EMAILJS_PRIVATE_KEY="your-emailjs-private-key"

# ── Cashier POS PIN ───────────────────
# PIN cashiers enter to unlock the standalone POS at /pos
POS_PIN="1234"

# ── Twilio SMS ────────────────────────────
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# ── Google Vision API (OCR) ───────────────
GOOGLE_VISION_API_KEY="your-google-vision-api-key"

# ── Firebase (Push Notifications) ─────────
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Payment (Optional) ────────────────────
CHAPA_SECRET_KEY="CHASECK_TEST-your-key-here"
CHAPA_PUBLIC_KEY="CHAPUBK_TEST-your-key-here"

# ── App Config ────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Cron Jobs ─────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret"
